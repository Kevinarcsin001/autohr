# =====================================================
# AutoHR 环境变量样例
# 用法: cp .env.example .env
# 生成密钥: make gen-keys && make gen-fernet
# =====================================================

# === General ===
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=please-change-me-in-production-at-least-32-chars-long

# === PostgreSQL ===
# 注意：宿主机端口（POSTGRES_PORT）默认 5433 避让本机其他项目；
# 容器内部仍走 5432，backend 通过 postgres:5432 访问。
POSTGRES_USER=autohr
POSTGRES_PASSWORD=autohr_dev
POSTGRES_DB=autohr
POSTGRES_PORT=5433
# DATABASE_URL 用于本地（非容器）开发，端口需与 POSTGRES_PORT 一致
DATABASE_URL=postgresql+asyncpg://autohr:autohr_dev@localhost:5433/autohr

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# === JWT (RS256) ===
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_PRIVATE_KEY_PATH=./backend/keys/private.pem
JWT_PUBLIC_KEY_PATH=./backend/keys/public.pem

# === Fernet (PII 列加密) ===
# 生成: make gen-fernet
FERNET_KEY=

# === MinIO / S3 兼容对象存储 ===
MINIO_ROOT_USER=autohr
MINIO_ROOT_PASSWORD=autohr_dev_secret
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=autohr
MINIO_SECRET_KEY=autohr_dev_secret
MINIO_BUCKET=resumes
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === LLM: 智谱 GLM ===
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-plus

# === LLM: 通义千问 ===
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-max

# === LLM Router 默认策略 ===
LLM_PRIMARY=zhipu
LLM_FALLBACK=qwen
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_CIRCUIT_BREAKER_FAILURES=3
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# === 上传限制 ===
MAX_UPLOAD_FILE_SIZE_MB=20
MAX_UPLOAD_BATCH_SIZE=100

# === Email IMAP (留空则禁用邮件抓取) ===
EMAIL_POLL_INTERVAL_MIN=15
EMAIL_IMAP_RETRY_BACKOFF_SECONDS=15,60,300,900,1800

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === OCR / Parser ===
PADDLE_OCR_LANG=ch
PDF_TEXT_DENSITY_THRESHOLD=100
PARSE_MIN_TEXT_LENGTH=50

# === 服务端口 ===
# FRONTEND_PORT 默认 3001 避让本机其他 Next.js 项目
BACKEND_PORT=8000
FRONTEND_PORT=3001

# === 生产部署（docker-compose.prod.yml）===
# 用于推送 / 拉取 GHCR 镜像的仓库路径，格式为 <owner>/<repo>（小写）
GITHUB_REPO=autohr/autohr
